// Copy to Secrets.xcconfig and fill in your values.
// cp Config/Secrets.xcconfig.example Config/Secrets.xcconfig

NEON_AUTH_BASE_URL = https:/$()/ep-xxx.neonauth.region.aws.neon.tech/neondb/auth
API_BASE_URL = http:/$()/localhost:3000/v1
WS_BASE_URL = ws:/$()/localhost:3000/ws
AUTH_ORIGIN = copare:/$()/

// Use your Mac's LAN IP when running on a physical device, e.g.:
// API_BASE_URL = http:/$()/192.168.1.10:3000/v1
// WS_BASE_URL = ws:/$()/192.168.1.10:3000/ws
