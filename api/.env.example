# Neon Postgres (pooled connection string from Neon Console)
DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Neon Auth base URL (Console → Auth → Auth URL)
NEON_AUTH_BASE_URL=https://ep-xxx.neonauth.region.aws.neon.tech/neondb/auth

PORT=3000
NODE_ENV=development

# APNs (copare-notifications worker only)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.copare.app
APNS_PRIVATE_KEY=
